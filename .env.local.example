# Copy this file to .env.local and fill in the values.
# Then add the same variables to Vercel via: vercel env add

# URL of your Google Apps Script Web App (doGet/doPost endpoint)
SHEETS_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Secret token — must match the TOKEN constant in your Apps Script
SHEETS_TOKEN=your-random-secret-token

# Credenciales del dashboard (las valida /api/login)
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=your-password

# Secreto para firmar la cookie de sesión (HMAC). Generar con: openssl rand -hex 32
AUTH_SECRET=your-random-session-secret

# --- Recordatorio de los viernes (Vercel Cron) ---
# Verifica que el cron lo dispara Vercel. Generar con: openssl rand -hex 32
CRON_SECRET=your-random-cron-secret

# Email vía Resend (https://resend.com). El from de prueba 'onboarding@resend.dev'
# solo envía a la dirección de tu propia cuenta Resend.
RESEND_API_KEY=re_xxxxxxxx
REMINDER_EMAIL_TO=tu-correo@gmail.com
# REMINDER_EMAIL_FROM=onboarding@resend.dev   # opcional, este es el default

# WhatsApp vía CallMeBot (https://www.callmebot.com/blog/free-api-whatsapp-messages/)
CALLMEBOT_PHONE=569XXXXXXXX
CALLMEBOT_APIKEY=123456

# URL del dashboard que va en el recordatorio (opcional, hay default)
# DASHBOARD_URL=https://investment-dashboard-bay-alpha.vercel.app
